---
import type { ui } from '../i18n/ui';

interface Props {
  t: typeof ui['es']['projects'];
}

const { t } = Astro.props;

const statusLabel = {
  live: t.status_live,
  building: t.status_building,
  planned: t.status_planned,
};
---

<section id="projects" class="projects">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t.label}</span>
      <h2>{t.heading} <span class="gradient-text">{t.heading_accent}</span></h2>
      <p>{t.subtitle}</p>
    </div>
    <div class="bento-grid">
      {t.items.map((project, i) => (
        <div class={`project-card ${i === 0 ? 'featured' : ''}`}>
          <div class="card-header">
            <span class={`status status-${project.status}`}>
              {statusLabel[project.status]}
            </span>
            {project.link && (
              <a href={project.link} class="card-link" aria-label={`Ver ${project.title}`}>↗</a>
            )}
          </div>
          <div class="card-body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
          <div class="card-footer">
            <div class="tags">
              {project.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 8rem 2rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-cyan);
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .project-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gradient);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .project-card:hover {
    border-color: rgba(124, 58, 237, 0.4);
    transform: translateY(-4px);
  }

  .project-card:hover::after {
    opacity: 0.03;
  }

  .project-card.featured {
    grid-column: span 2;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.08), rgba(6, 182, 212, 0.05));
    border-color: rgba(124, 58, 237, 0.2);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .status {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .status-live {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .status-building {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .status-planned {
    background: rgba(161, 161, 170, 0.15);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .card-link {
    font-size: 1.25rem;
    color: var(--text-secondary);
    transition: color 0.2s;
    position: relative;
    z-index: 1;
  }

  .card-link:hover {
    color: var(--accent-cyan);
  }

  .card-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .card-body p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .card-footer {
    margin-top: auto;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .project-card.featured {
      grid-column: span 1;
    }
  }
</style>
