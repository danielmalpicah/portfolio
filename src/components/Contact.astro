---
import type { ui } from '../i18n/ui';

interface Props {
  t: typeof ui['es']['contact'];
}

const { t } = Astro.props;

// Reemplaza con tu endpoint de Formspree: https://formspree.io/f/TU_ID
const FORMSPREE = 'https://formspree.io/f/mdavqwjy';
const WHATSAPP = 'https://wa.me/525971035212';
---

<section id="contact" class="contact">
  <div class="container">
    <div class="contact-inner" data-animate>
      <span class="section-label">{t.label}</span>
      <h2>{t.heading} <span class="gradient-text">{t.heading_accent}</span></h2>
      <p class="subtitle">{t.subtitle}</p>

      <form
        id="contact-form"
        action={FORMSPREE}
        method="POST"
        class="form"
        novalidate
      >
        <!-- Honeypot antispam -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" aria-hidden="true" />

        <div class="form-row">
          <div class="field">
            <label for="cf-name">{t.form_name}</label>
            <input
              type="text"
              id="cf-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Daniel Malpica"
            />
          </div>
          <div class="field">
            <label for="cf-email">{t.form_email}</label>
            <input
              type="text"
              inputmode="email"
              id="cf-email"
              name="email"
              required
              autocomplete="email"
              placeholder="hola@empresa.com"
            />
          </div>
        </div>

        <div class="field">
          <label for="cf-message">{t.form_message}</label>
          <textarea
            id="cf-message"
            name="message"
            rows="5"
            required
            placeholder="Cuéntame sobre tu proyecto..."
          ></textarea>
        </div>

        <button type="submit" class="submit-btn">
          <span class="btn-text">{t.form_submit}</span>
          <span class="btn-loading" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </span>
        </button>

        <p class="form-feedback success" role="status" aria-live="polite">{t.form_success}</p>
        <p class="form-feedback error" role="alert">{t.form_error}</p>
      </form>

      <div class="divider">
        <span>{t.or}</span>
      </div>

      <div class="alt-links">
        <a href={WHATSAPP} target="_blank" rel="noopener noreferrer" class="alt-btn whatsapp">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a href="https://github.com/danielmalpicah" target="_blank" rel="noopener noreferrer" class="alt-btn github">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          {t.github_cta}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = form.querySelector('.btn-text') as HTMLElement;
    const btnLoading = form.querySelector('.btn-loading') as HTMLElement;
    const successMsg = form.querySelector('.form-feedback.success') as HTMLElement;
    const errorMsg = form.querySelector('.form-feedback.error') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline-flex';
      successMsg.style.display = 'none';
      errorMsg.style.display = 'none';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          successMsg.style.display = 'block';
        } else {
          throw new Error();
        }
      } catch {
        errorMsg.style.display = 'block';
      } finally {
        submitBtn.disabled = false;
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
      }
    });
  }
</script>

<style>
  .contact {
    padding: 8rem 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .contact .container {
    max-width: 680px;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .contact-inner .section-label {
    margin-bottom: 0;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 480px;
  }

  /* Form */
  .form {
    width: 100%;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }

  input,
  textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.9rem;
    width: 100%;
    transition: border-color 0.2s;
    resize: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--text-muted);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent-violet);
  }

  .submit-btn {
    margin-top: 0.25rem;
    padding: 0.875rem 2rem;
    background: var(--gradient);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    transition: opacity 0.2s, transform 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .submit-btn:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-loading {
    display: none;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .form-feedback {
    display: none;
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
  }

  .form-feedback.success {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .form-feedback.error {
    color: #f87171;
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.2);
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 0.5rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Alt links */
  .alt-links {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .alt-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    transition: all 0.2s;
  }

  .alt-btn:hover {
    background: var(--surface-hover);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  .alt-btn.whatsapp:hover {
    border-color: rgba(37, 211, 102, 0.4);
    color: #25d366;
  }

  .alt-btn.github:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-primary);
  }

  @media (max-width: 540px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
